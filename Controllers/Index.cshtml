@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Circulation Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Circulation</h1>
        <a asp-action="Checkout" class="btn btn-primary shadow-sm">
            <i class="fas fa-barcode fa-sm me-1"></i> New Checkout
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary">Active & Past Transactions</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Borrower</th>
                            <th>Book Title</th>
                            <th>Checkout Date</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@item.User?.FullName</div>
                                    <div class="small text-muted">@item.User?.Email</div>
                                </td>
                                <td>
                                    @if (item.IsOverdue)
                                    {
                                        <i class="fas fa-exclamation-triangle text-danger me-1" title="Overdue"></i>
                                    }
                                    @item.Book?.Title
                                </td>
                                <td class="small">@item.BorrowDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="small">@item.DueDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td>
                                    @{
                                        var color = item.Status == "Borrowed" ? "bg-primary" : item.Status.Contains("Overdue") ? "bg-danger" : "bg-success";
                                    }
                                    <span class="badge rounded-pill @color">@item.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@item.TransactionId" class="btn btn-sm btn-outline-info me-1"><i class="fas fa-eye"></i></a>
                                    @if (item.ReturnDate == null)
                                    {
                                        <form asp-action="Return" asp-route-id="@item.TransactionId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-undo me-1"></i> Process Return
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Returned: @item.ReturnDate?.ToLocalTime().ToString("MMM dd")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">
        <div class="toast show align-items-center text-white bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">@TempData["ErrorMessage"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}