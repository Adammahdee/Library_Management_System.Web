@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Borrow History";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Borrow History</h2>
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Borrow Date</th>
                                <th>Due Date</th>
                                <th>Return Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.Book?.Title
                                    </td>

                                    <td>
                                        @item.BorrowDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @item.DueDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @(item.ReturnDate?.ToString("dd MMM yyyy") ?? "Not Returned")
                                    </td>

                                    <td>

                                        @if (item.Status == "Returned")
                                        {
                                            <span class="badge bg-success">
                                                Returned
                                            </span>
                                        }
                                        else if (item.Status == "Overdue")
                                        {
                                            <span class="badge bg-danger">
                                                Overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">
                                                Borrowed
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No borrowing history found.
                </div>
            }

        </div>

    </div>

</div>