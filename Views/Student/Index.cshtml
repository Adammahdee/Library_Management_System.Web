@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Student Portal";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Student Portal</h2>
    </div>

    <div class="row mb-4">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Active Loans</h6>
                    <h3>@ViewBag.ActiveLoansCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Overdue Books</h6>
                    <h3>@ViewBag.OverdueCount</h3>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Unpaid Fines</h6>
                    <h3>@ViewBag.UnpaidFines</h3>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">Recent Borrow Activity</h5>
        </div>

        <div class="card-body">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Borrow Date</th>
                                <th>Due Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        @item.Book?.Title
                                    </td>

                                    <td>
                                        @item.BorrowDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @item.DueDate.ToString("dd MMM yyyy")
                                    </td>

                                    <td>

                                        @if (item.Status == "Overdue")
                                        {
                                            <span class="badge bg-danger">
                                                Overdue
                                            </span>
                                        }
                                        else if (item.Status == "Returned")
                                        {
                                            <span class="badge bg-success">
                                                Returned
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">
                                                Borrowed
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No recent activity found.
                </div>
            }

        </div>

    </div>

</div>