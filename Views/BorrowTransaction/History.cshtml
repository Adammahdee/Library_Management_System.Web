@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Transaction History";
    Layout = "_AdminLayout";
    
    // Capture filter state
    var search = ViewBag.Search as string;
    var status = ViewBag.Status as string;
    var sort = ViewBag.Sort as string ?? "borrow_desc";
    
    // Paging state from ViewBag
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    
    var statusOptions = ViewBag.StatusOptions as List<string> ?? new List<string>();
}

<div class="container-fluid px-4 mt-4 pb-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Transaction History</h1>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Circulation
        </a>
    </div>

    <form method="get" class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted text-uppercase fw-bold">Search</label>
                    <input class="form-control" name="search" value="@search" placeholder="Borrower, book, or email..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted text-uppercase fw-bold">Status</label>
                    <select class="form-select" name="status">
                        <option value="">All Statuses</option>
                        @foreach (var s in statusOptions) { <option value="@s" selected="@(status == s)">@s</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted text-uppercase fw-bold">Sort By</label>
                    <select class="form-select" name="sort">
                        <option value="borrow_desc" selected="@(sort=="borrow_desc")">Borrow Date (Newest)</option>
                        <option value="borrow_asc" selected="@(sort=="borrow_asc")">Borrow Date (Oldest)</option>
                        <option value="due_desc" selected="@(sort=="due_desc")">Due Date (Latest)</option>
                        <option value="due_asc" selected="@(sort=="due_asc")">Due Date (Earliest)</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">
                        <i class="fas fa-filter me-1"></i> Apply Filters
                    </button>
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr class="small text-uppercase text-muted">
                        <th class="ps-4">Borrower</th>
                        <th>Book</th>
                        <th>Borrow Date</th>
                        <th>Due Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                        <th>Fines</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="fas fa-history fa-2x mb-3 d-block opacity-25"></i>
                                No history records found matching these criteria.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var tx in Model)
                        {
                            var unpaid = tx.Fines?.Where(f => !f.IsPaid).Sum(f => f.Amount) ?? 0;
                            var hasTotalFines = tx.Fines?.Any() ?? false;
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@tx.User?.FullName</div>
                                    <div class="small text-muted">@tx.User?.Email</div>
                                </td>
                                <td><div class="text-truncate" style="max-width: 200px;">@tx.Book?.Title</div></td>
                                <td class="small">@tx.BorrowDate.ToString("yyyy-MM-dd")</td>
                                <td class="small">@tx.DueDate.ToString("yyyy-MM-dd")</td>
                                <td class="small">@(tx.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>
                                    @{
                                        var badgeClass = tx.Status switch {
                                            "Returned" => "bg-success",
                                            "Borrowed" => "bg-primary",
                                            "Overdue" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge rounded-pill @badgeClass">@tx.Status</span>
                                </td>
                                <td>
                                    @if (unpaid > 0) { <span class="text-danger fw-bold">@unpaid.ToString("C")</span> }
                                    else if (hasTotalFines) { <span class="text-success small fw-bold"><i class="fas fa-check me-1"></i> Paid</span> }
                                    else { <span class="text-muted">-</span> }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Details" asp-route-id="@tx.TransactionId" class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-eye"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">Total records: <span class="fw-bold">@totalItems</span></div>
        
        @if (totalPages > 1)
        {
            <nav aria-label="History Pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link shadow-none" asp-action="History" asp-route-page="@(currentPage - 1)" 
                           asp-route-search="@search" asp-route-status="@status" asp-route-sort="@sort">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                    <li class="page-item disabled"><span class="page-link text-dark fw-bold">Page @currentPage of @totalPages</span></li>
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link shadow-none" asp-action="History" asp-route-page="@(currentPage + 1)" 
                           asp-route-search="@search" asp-route-status="@status" asp-route-sort="@sort">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
