@model IEnumerable<Library_Management_System.Web.Models.Author>

@{
    ViewData["Title"] = "Authors Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    @if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mt-4 mb-0" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        @TempData["SuccessMessage"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>
    </div>
}
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold">
                Authors
            </h1>

            <p class="text-muted mb-0">
                Manage library authors and their associated books.
            </p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm me-1"></i> Add New Author
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary">Library Authors</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Author Name</th>
                            <th>Books Written</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    No authors found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-bold text-dark">
                                        @item.AuthorName
                                    </td>
                                    <td>
                                        <span class="badge bg-primary-subtle text-primary border">
                                            @(item.BookAuthors?.Count ?? 0) Books
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@item.AuthorId" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fas fa-edit"></i></a>
                                            <a asp-action="Details" asp-route-id="@item.AuthorId" class="btn btn-sm btn-outline-info mx-1" title="Details"><i class="fas fa-eye"></i></a>
                                            <button type="button" class="btn btn-sm btn-outline-danger shadow-none" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteAuthorModal" 
                                                    data-id="@item.AuthorId" data-name="@item.AuthorName" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteAuthorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form asp-action="Delete" method="post">
                    <div class="modal-header bg-danger text-white border-0">
                        <h5 class="modal-title fw-bold"><i class="fas fa-exclamation-triangle me-2"></i>Remove Author</h5>
                        <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4">
                        <div class="text-center">

                            <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                style="width:70px; height:70px;">

                                <i class="fas fa-trash-alt text-danger fa-2x"></i>

                            </div>

                            <h5 class="fw-bold text-dark mb-2">
                                Delete Author
                            </h5>

                            <p class="text-muted mb-1">
                                You are about to remove:
                            </p>

                            <h4 id="deleteAuthorName" class="fw-bold text-danger mb-3"></h4>

                            <input type="hidden" name="id" id="deleteAuthorId" />

                            <div class="alert alert-warning small text-start mt-3 mb-0">
                                <i class="fas fa-info-circle me-1"></i>
                                This action will remove the author from all linked books and cannot be undone.
                            </div>

                        </div>
                    </div>
                    <div class="modal-footer border-0 bg-light">
                        <button type="button" class="btn btn-link text-secondary text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">Delete Author</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var deleteModal = document.getElementById('deleteAuthorModal')
        deleteModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget
            var id = button.getAttribute('data-id')
            var name = button.getAttribute('data-name')
            
            deleteModal.querySelector('#deleteAuthorName').textContent = name
            deleteModal.querySelector('#deleteAuthorId').value = id
        })
    </script>
}