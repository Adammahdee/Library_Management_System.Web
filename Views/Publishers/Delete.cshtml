@model Library_Management_System.Web.Models.Publisher

@{
    ViewData["Title"] = "Delete Publisher";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="mb-4 mt-4">
        <h1 class="h3 mb-0 text-danger fw-bold">Delete Publisher</h1>
        <p class="text-muted">Are you sure you want to permanently remove this publisher?</p>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 border-top border-danger border-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="fas fa-exclamation-triangle text-danger fa-2x"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">@Model.PublisherName</h5>
                            <p class="mb-0 text-muted small">ID: #@Model.PublisherId</p>
                        </div>
                    </div>

                    <div class="alert alert-warning border-0 small">
                        <i class="fas fa-info-circle me-1"></i>
                        <strong>Warning:</strong> Deleting this publisher will set the publisher reference to null for @(Model.Books?.Count ?? 0) books.
                    </div>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="row mb-2">
                            <div class="col-4 text-muted small text-uppercase fw-bold">Email</div>
                            <div class="col-8">@(Model.Email ?? "N/A")</div>
                        </div>
                        <div class="row">
                            <div class="col-4 text-muted small text-uppercase fw-bold">Books Count</div>
                            <div class="col-8">@(Model.Books?.Count ?? 0) registered titles</div>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="PublisherId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4">Delete Permanently</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
