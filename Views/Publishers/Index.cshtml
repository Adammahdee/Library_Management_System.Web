@model IEnumerable<Library_Management_System.Web.Models.Publisher>

@{
    ViewData["Title"] = "Publisher Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">

    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">

        <div>
            <h1 class="h3 fw-bold text-dark mb-1">
                Publishers
            </h1>

            <p class="text-muted mb-0">
                Manage publisher records for the library catalog.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus me-1"></i>
            Add Publisher
        </a>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white border-bottom py-3">

            <h6 class="m-0 fw-bold text-primary">
                Publisher List
            </h6>

        </div>

        <div class="card-body p-0">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="bg-light">

                        <tr class="small text-uppercase text-muted">

                            <th class="ps-4">
                                Publisher Name
                            </th>

                            <th class="text-end pe-4">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>

                                    <td class="ps-4 py-3 fw-semibold text-dark">
                                        @item.PublisherName
                                    </td>

                                    <td class="text-end pe-4">

                                        <div class="btn-group">

                                            <a asp-action="Edit"
                                               asp-route-id="@item.PublisherId"
                                               class="btn btn-sm btn-outline-secondary"
                                               title="Edit">

                                                <i class="fas fa-edit"></i>

                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.PublisherId"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Delete">

                                                <i class="fas fa-trash"></i>

                                            </a>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="2"
                                    class="text-center py-5 text-muted">

                                    No publishers found.

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>