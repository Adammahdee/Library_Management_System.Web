<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Library</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Library_Management_System.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">University Library</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav" aria-controls="appNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="appNav" class="navbar-collapse collapse">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Users" asp-action="Index">User Management</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Books" asp-action="Index">Books</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Authors" asp-action="Index">Authors</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">Categories</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Publishers" asp-action="Index">Publishers</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="BorrowTransaction" asp-action="Index">Borrow Transactions</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="FineManagement">Fine Management</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Reports/Analytics</a></li>
                            }
                            else if (User.IsInRole("Librarian"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Librarian" asp-action="Index">Dashboard</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Books" asp-action="Index">Books</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Authors" asp-action="Index">Authors</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index">Categories</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Publishers" asp-action="Index">Publishers</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="BorrowTransaction" asp-action="Index">Borrow Transactions</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="BorrowTransaction" asp-action="Index">Returns</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="FineManagement">Fine Management</a></li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Index">Student Portal</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="MyBooks">My Borrowed Books</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="History">Borrow History</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Student" asp-action="Fines">My Fines</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Books" asp-action="Index">Catalog Search</a></li>
                            }
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="navbar-actions">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="d-flex align-items-center">
                                <span class="user-chip me-2">
                                    <i class="fas fa-user-circle me-1"></i> @User.Identity.Name
                                </span>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Sign out</button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
                            <a class="btn btn-primary btn-sm ms-2" asp-controller="Account" asp-action="Register">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-content">
        <div class="container-fluid app-container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="footer text-muted border-top">
        <div class="container text-center">
            &copy; 2026 - University Library Resource Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Student Portal";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h2 mb-0">Welcome back, @User.Identity?.Name</h1>
            <p class="text-muted">Manage your borrowed books and library account</p>
        </div>
        <a asp-controller="Books" asp-action="Index" class="btn btn-primary shadow-sm">
            <i class="fas fa-search me-1"></i> Search Catalog
        </a>
    </div>

    <div class="row g-4 mb-5">
        <!-- Active Loans Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="flex-shrink-0 bg-primary bg-opacity-10 text-primary p-3 rounded">
                            <i class="fas fa-book-reader fa-2x"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="card-subtitle text-muted text-uppercase small fw-bold">Active Loans</h6>
                            <h2 class="card-title mb-0">@ViewBag.ActiveLoansCount</h2>
                        </div>
                    </div>
                    <a asp-action="MyBooks" class="btn btn-sm btn-outline-primary w-100 mt-2">View My Books</a>
                </div>
            </div>
        </div>

        <!-- Overdue Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="flex-shrink-0 @(ViewBag.OverdueCount > 0 ? "bg-danger" : "bg-success") bg-opacity-10 @(ViewBag.OverdueCount > 0 ? "text-danger" : "text-success") p-3 rounded">
                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="card-subtitle text-muted text-uppercase small fw-bold">Overdue Items</h6>
                            <h2 class="card-title mb-0">@ViewBag.OverdueCount</h2>
                        </div>
                    </div>
                    <a asp-action="MyBooks" class="btn btn-sm @(ViewBag.OverdueCount > 0 ? "btn-danger" : "btn-outline-secondary") w-100 mt-2">Check Deadlines</a>
                </div>
            </div>
        </div>

        <!-- Fines Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="flex-shrink-0 bg-warning bg-opacity-10 text-warning p-3 rounded">
                            <i class="fas fa-hand-holding-usd fa-2x"></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="card-subtitle text-muted text-uppercase small fw-bold">Pending Fines</h6>
                            <h2 class="card-title mb-0">@ViewBag.UnpaidFines.ToString("C")</h2>
                        </div>
                    </div>
                    <a asp-action="Fines" class="btn btn-sm btn-outline-warning w-100 mt-2">Fine Details</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i>Recent Activity</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Book Title</th>
                            <th>Date</th>
                            <th>Due Date</th>
                            <th class="text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.Book?.Title</td>
                                <td class="small">@item.BorrowDate.ToString("MMM dd, yyyy")</td>
                                <td class="small">@item.DueDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-end pe-4">
                                    <span class="badge rounded-pill @(item.Status == "Borrowed" ? "bg-primary" : item.Status == "Overdue" ? "bg-danger" : "bg-secondary")">@item.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>