@model IEnumerable<Library_Management_System.Web.Models.BorrowTransaction>

@{
    ViewData["Title"] = "Borrow History";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 class="h2 mb-0">My Borrow History</h1>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Portal
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i>Past Borrow Transactions</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Book Title</th>
                            <th>Borrow Date</th>
                            <th>Due Date</th>
                            <th>Return Date</th>
                            <th class="text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    No past borrowing records found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@item.Book?.Title</td>
                                    <td class="small">@item.BorrowDate.ToString("MMM dd, yyyy")</td>
                                    <td class="small">@item.DueDate.ToString("MMM dd, yyyy")</td>
                                    <td class="small">@(item.ReturnDate?.ToString("MMM dd, yyyy") ?? "-")</td>
                                    <td class="text-end pe-4">
                                        @{
                                            var badgeClass = item.Status switch
                                            {
                                                "Returned" => "bg-success",
                                                "Returned (Overdue)" => "bg-warning text-dark",
                                                "Cancelled" => "bg-secondary",
                                                _ => "bg-info"
                                            };
                                        }
                                        <span class="badge rounded-pill @badgeClass">@item.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>