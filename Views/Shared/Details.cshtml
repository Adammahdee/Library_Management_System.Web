@model Library_Management_System.Web.Models.Author

@{
    ViewData["Title"] = "Author Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Author Details</h1>
        <div class="btn-group shadow-sm">
            <a asp-action="Edit" asp-route-id="@Model.AuthorId" class="btn btn-primary btn-sm">
                <i class="fas fa-edit fa-sm me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left fa-sm me-1"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Author Info -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Information</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-sm-3 text-muted small fw-bold text-uppercase">Full Name</div>
                        <div class="col-sm-9 fs-5 fw-bold text-dark">@Model.AuthorName</div>
                    </div>
                </div>
            </div>

            <!-- Books by this Author -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Books in Collection</h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (Model.BookAuthors != null && Model.BookAuthors.Any())
                        {
                            foreach (var ba in Model.BookAuthors)
                            {
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@ba.BookId" 
                                   class="list-group-item list-group-item-action py-3 d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold text-dark">@ba.Book?.Title</div>
                                        <div class="small text-muted">ISBN: @ba.Book?.ISBN</div>
                                    </div>
                                    <i class="fas fa-chevron-right text-light"></i>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">No books associated with this author.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>