@model Library_Management_System.Web.Models.ApplicationUser
@using Library_Management_System.Web.Models

@{
    ViewData["Title"] = "User Details";
    Layout = "_AdminLayout";

    var activeLoans = ViewBag.ActiveLoans as List<BorrowTransaction> ?? new();
    var roles = ViewBag.UserRoles as IList<string> ?? new List<string>();
    var availableRoles = ViewBag.AvailableRoles as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var allRoles = ViewBag.AllRoles as List<string> ?? new List<string>();
    var borrowHistory = ViewBag.BorrowHistory as List<BorrowTransaction> ?? new();
    var activityHistory = ViewBag.ActivityHistory as List<AuditLog> ?? new();
    var isLocked = Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.UtcNow;
}

<div class="container-fluid px-4 mt-4">
    <h1 class="h3 mb-4">User Details</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@Model.FullName</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@(Model.Department?.DepartmentName ?? "N/A")</dd>
                <dt class="col-sm-3">Roles</dt>
                <dd class="col-sm-9">
                    @if (roles.Any())
                    {
                        foreach (var role in roles) { <span class="badge bg-info text-dark me-1">@role</span> }
                    }
                    else { <span class="text-muted">No assigned roles</span> }
                </dd>
                <dt class="col-sm-3">Account Status</dt>
                <dd class="col-sm-9">
                    @if (isLocked) { <span class="badge bg-danger">Locked</span> }
                    else if (Model.IsActive) { <span class="badge bg-success">Active</span> }
                    else { <span class="badge bg-secondary">Inactive</span> }
                </dd>
            </dl>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header">Advanced Role Assignment</div>
                <div class="card-body">
                    <form asp-action="SyncRoles" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Assign roles</label>
                            <select class="form-select" name="roles" multiple size="6">
                                @foreach (var role in allRoles)
                                {
                                    <option value="@role" selected="@(roles.Contains(role))">@role</option>
                                }
                            </select>
                            <div class="form-text">Hold Ctrl/Cmd to select multiple roles.</div>
                        </div>
                        <button type="submit" class="btn btn-primary">Save Roles</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header">Administration Tools</div>
                <div class="card-body d-flex align-items-start gap-2 flex-wrap">
                    @if (isLocked)
                    {
                        <form asp-action="UnlockUser" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-success">Unlock Account</button></form>
                    }
                    else
                    {
                        <form asp-action="LockUser" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-danger">Lock Account</button></form>
                    }
                    <form asp-action="ToggleStatus" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-warning">Toggle Active</button></form>
                    <form asp-action="PayAllFines" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id" /><button type="submit" class="btn btn-outline-success">Mark All Fines Paid</button></form>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header">Admin Password Reset</div>
        <div class="card-body">
            <form asp-action="ResetPassword" method="post" class="row g-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="col-md-5"><label class="form-label">New Password</label><input type="password" name="newPassword" class="form-control" required minlength="8" /></div>
                <div class="col-md-5"><label class="form-label">Confirm Password</label><input type="password" name="confirmPassword" class="form-control" required minlength="8" /></div>
                <div class="col-md-2 d-grid"><label class="form-label">&nbsp;</label><button type="submit" class="btn btn-outline-primary">Reset</button></div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header">Active Loans</div>
        <div class="card-body">
            @if (!activeLoans.Any()) { <p class="text-muted mb-0">No active loans.</p> }
            else { <ul class="mb-0">@foreach (var loan in activeLoans) { <li>@loan.Book?.Title (Due: @loan.DueDate.ToString("yyyy-MM-dd"), Status: @loan.Status)</li> }</ul> }
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header">Borrowing History</div>
        <div class="table-responsive">
            <table class="table table-striped mb-0">
                <thead><tr><th>Book</th><th>Borrow Date</th><th>Due Date</th><th>Return Date</th><th>Status</th><th>Outstanding Fines</th></tr></thead>
                <tbody>
                @if (!borrowHistory.Any()) { <tr><td colspan="6" class="text-center text-muted py-3">No borrowing records found.</td></tr> }
                else
                {
                    foreach (var tx in borrowHistory)
                    {
                        var unpaid = tx.Fines.Where(f => !f.IsPaid).Sum(f => f.Amount);
                        <tr><td>@tx.Book?.Title</td><td>@tx.BorrowDate.ToString("yyyy-MM-dd")</td><td>@tx.DueDate.ToString("yyyy-MM-dd")</td><td>@(tx.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td><td>@tx.Status</td><td>@(unpaid > 0 ? unpaid.ToString("C") : "-")</td></tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header">Payment History</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr class="small text-uppercase text-muted">
                        <th class="ps-4">Book / Transaction</th>
                        <th>Fine Created</th>
                        <th>Paid At</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @{ var payments = ViewBag.PaymentHistory as List<Fine>; }
                @if (payments == null || !payments.Any()) { <tr><td colspan="5" class="text-center text-muted py-3">No payment records found.</td></tr> }
                else
                {
                    foreach (var fine in payments)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@fine.BorrowTransaction?.Book?.Title</div>
                                <div class="small text-muted">Transaction #@fine.TransactionId</div>
                            </td>
                            <td class="small">@fine.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="small text-success fw-bold">@(fine.PaidAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                            <td class="text-end fw-bold">@fine.Amount.ToString("C")</td>
                            <td class="text-end pe-4">
                                <a asp-action="DownloadReceipt" asp-route-fineId="@fine.FineId" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-download me-1"></i> Receipt
                                </a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header">Login & Activity History (Recent 50)</div>
        <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
                <thead><tr><th>Date</th><th>Action</th><th>Entity</th><th>Description</th></tr></thead>
                <tbody>
                @if (!activityHistory.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-3">No activity records found.</td></tr>
                }
                else
                {
                    foreach (var log in activityHistory)
                    {
                        <tr>
                            <td>@log.LogDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@log.ActionType</td>
                            <td>@log.TableName</td>
                            <td>@(string.IsNullOrWhiteSpace(log.Description) ? "-" : log.Description)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Back to Users</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit User</a>
</div>
