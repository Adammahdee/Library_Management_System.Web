@model IEnumerable<Library_Management_System.Web.Models.Book>

@{
    ViewData["Title"] = "Book Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Books</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm me-1"></i> Add New Book
        </a>
    </div>

    <form asp-action="Index" method="get" class="row g-3 mb-4">

        <div class="col-md-3">
            <input
                type="text"
                name="searchString"
                value="@ViewData["CurrentFilter"]"
                class="form-control"
                placeholder="Search books..." />
        </div>

        <div class="col-md-2">
            <select name="categoryId" class="form-select">

                <option value="">
                    All Categories
                </option>

                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.CategoryId"
                        selected="@(ViewData["CurrentCategory"]?.ToString() == category.CategoryId.ToString())">

                        @category.CategoryName

                    </option>
                }

            </select>
        </div>

        <div class="col-md-2">
            <select name="publisherId" class="form-select">

                <option value="">
                    All Publishers
                </option>

                @foreach (var publisher in ViewBag.Publishers)
                {
                    <option value="@publisher.PublisherId"
                        selected="@(ViewData["CurrentPublisher"]?.ToString() == publisher.PublisherId.ToString())">

                        @publisher.PublisherName

                    </option>
                }

            </select>
        </div>

        <div class="col-md-2">
            <select name="availabilityFilter" class="form-select">

                <option value="">
                    All Availability
                </option>

                <option value="available"
                    selected="@(ViewData["CurrentAvailability"]?.ToString() == "available")">

                    Available

                </option>

                <option value="unavailable"
                    selected="@(ViewData["CurrentAvailability"]?.ToString() == "unavailable")">

                    Unavailable

                </option>

            </select>
        </div>

        <div class="col-md-2">
            <select name="sortOrder" class="form-select">

                <option value="">
                    Sort A-Z
                </option>

                <option value="title_desc"
                    selected="@(ViewData["CurrentSort"]?.ToString() == "title_desc")">

                    Sort Z-A

                </option>

                <option value="newest"
                    selected="@(ViewData["CurrentSort"]?.ToString() == "newest")">

                    Newest

                </option>

                <option value="oldest"
                    selected="@(ViewData["CurrentSort"]?.ToString() == "oldest")">

                    Oldest

                </option>

            </select>
        </div>

        <div class="col-md-1 d-grid">

            <button type="submit" class="btn btn-primary">
                Search
            </button>

        </div>

        <div class="col-md-1 d-grid">

            <a asp-action="Index"
                class="btn btn-outline-secondary">

                Reset

            </a>

        </div>

    </form>
    
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary">Library Catalog</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Title</th>
                            <th>ISBN</th>
                            <th>Category</th>
                            <th class="text-end">Stock</th>
                            <th class="text-end">Available</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    No books found in the catalog.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-bold text-dark">@item.Title</td>
                                    <td><code class="small fw-bold">@item.ISBN</code></td>
                                <td>@item.Category?.CategoryName</td>
                                <td class="text-end">@item.TotalCopies</td>
                                <td class="text-end">@item.AvailableCopies</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fas fa-edit"></i></a>
                                            <a asp-action="Details" asp-route-id="@item.BookId" class="btn btn-sm btn-outline-info mx-1" title="Details"><i class="fas fa-eye"></i></a>
                                            <form asp-action="Delete" asp-route-id="@item.BookId" method="post" class="d-inline" onsubmit="return confirm('Permanently delete this book?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @{
        var pageIndex = ViewData["PageIndex"] as int? ?? 1;
        var totalPages = ViewData["TotalPages"] as int? ?? 1;
        var prevDisabled = pageIndex <= 1 ? "disabled" : "";
        var nextDisabled = pageIndex >= totalPages ? "disabled" : "";
    }

    <div class="d-flex justify-content-between align-items-center mt-4 mb-5">
        <div class="text-muted small">
            Showing Page @pageIndex of @totalPages
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @prevDisabled">
                    <a class="page-link shadow-none"
                        asp-action="Index"
                        asp-route-pageNumber="@(pageIndex - 1)"
                        asp-route-searchString="@ViewData["CurrentFilter"]"
                        asp-route-sortOrder="@ViewData["CurrentSort"]"
                        asp-route-categoryId="@ViewData["CurrentCategory"]"
                        asp-route-publisherId="@ViewData["CurrentPublisher"]"
                        asp-route-availabilityFilter="@ViewData["CurrentAvailability"]">

                         <i class="fas fa-chevron-left me-1"></i> Previous

                    </a>
                </li>
                <li class="page-item @nextDisabled">
                    <a class="page-link shadow-none"
                        asp-action="Index"
                        asp-route-pageNumber="@(pageIndex + 1)"
                        asp-route-searchString="@ViewData["CurrentFilter"]"
                        asp-route-sortOrder="@ViewData["CurrentSort"]"
                        asp-route-categoryId="@ViewData["CurrentCategory"]"
                        asp-route-publisherId="@ViewData["CurrentPublisher"]"
                        asp-route-availabilityFilter="@ViewData["CurrentAvailability"]">

                         Next <i class="fas fa-chevron-right ms-1"></i>

                    </a>
                </li>
            </ul>
        </nav>
    </div>
</div>