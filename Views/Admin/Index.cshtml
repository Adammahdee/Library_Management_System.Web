@model Library_Management_System.Web.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Dashboard</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Library Overview</li>
    </ol>

    <div class="row">
        <!-- Total Books -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Total Books</div>
                        <div class="h2 mb-0 fw-bold">@Model.TotalBooks</div>
                    </div>
                    <i class="fas fa-book fa-2x opacity-50"></i>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between small">
                    <a class="text-white stretched-link" asp-controller="Books" asp-action="Index">View Catalog</a>
                    <div class="text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>

        <!-- Total Users -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Active Users</div>
                        <div class="h2 mb-0 fw-bold">@Model.TotalUsers</div>
                    </div>
                    <i class="fas fa-users fa-2x opacity-50"></i>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between small">
                    <a class="text-white stretched-link" asp-controller="Users" asp-action="Index">Manage Users</a>
                    <div class="text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>

        <!-- Overdue Books -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-white-50 text-uppercase fw-bold">Overdue Items</div>
                        <div class="h2 mb-0 fw-bold">@Model.OverdueBooks</div>
                    </div>
                    <i class="fas fa-clock fa-2x opacity-50"></i>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between small">
                    <a class="text-white stretched-link" asp-controller="BorrowTransaction" asp-action="Index">Process Returns</a>
                    <div class="text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>

        <!-- Pending Fines -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-warning text-dark mb-4">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div class="small text-dark-50 text-uppercase fw-bold">Outstanding Fines</div>
                        <div class="h2 mb-0 fw-bold">@Model.TotalFineAmount.ToString("C")</div>
                        <div class="small fw-bold">@Model.PendingFines pending fines</div>
                    </div>
                    <i class="fas fa-hand-holding-usd fa-2x opacity-50"></i>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between small text-dark">
                    <a class="text-dark stretched-link" asp-action="FineManagement">Review Fines</a>
                    <div><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-chart-pie me-1"></i> Circulation Summary</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            Currently Borrowed <span class="badge bg-primary rounded-pill">@Model.TotalBorrowedBooks</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            Total Returns Processed <span class="badge bg-success rounded-pill">@Model.ReturnedBooks</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            Currently Overdue <span class="badge bg-danger rounded-pill">@Model.OverdueBooks</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-tags me-1"></i> Popular Categories (30 Days)</h6>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        @if (!Model.TopCategories.Any())
                        {
                            <div class="text-center py-3 text-muted small">No recent activity.</div>
                        }
                        else
                        {
                            foreach (var cat in Model.TopCategories)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span>@cat.CategoryName</span>
                                    <span class="badge bg-info text-dark rounded-pill">@cat.BorrowCount borrows</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Monthly Fine Revenue Chart -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 mb-4 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-chart-line me-1"></i> Fine Revenue (Last 6 Months)</h6>
                </div>
                <div class="card-body d-flex align-items-center">
                    <canvas id="revenueChart" width="100%" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-danger"><i class="fas fa-exclamation-circle me-1"></i> Recent Overdue Items</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="ps-4">Borrower</th>
                                    <th>Book Title</th>
                                    <th>Due Date</th>
                                    <th class="text-end pe-4">Days Overdue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.OverdueTransactions.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4 text-muted">No items are currently overdue.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var item in Model.OverdueTransactions)
                                    {
                                        <tr>
                                            <td class="ps-4">@item.BorrowerName</td>
                                            <td class="fw-bold">@item.BookTitle</td>
                                            <td>@item.DueDate.ToShortDateString()</td>
                                            <td class="text-end pe-4 fw-bold text-danger">@item.DaysOverdue</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0 mb-5">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary"><i class="fas fa-user-shield me-1"></i> Top 5 Users with Highest Outstanding Fines</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="small text-uppercase text-muted">
                                    <th class="ps-4">Borrower</th>
                                    <th class="text-end pe-4">Total Outstanding</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.TopFineUsers.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-4 text-muted">No outstanding fines.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var user in Model.TopFineUsers)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold">@user.FullName</div>
                                                <div class="small text-muted">@user.Email</div>
                                            </td>
                                            <td class="text-end pe-4 fw-bold text-danger">@user.TotalFineAmount.ToString("C")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const ctx = document.getElementById('revenueChart').getContext('2d');
            const labels = @Html.Raw(Json.Serialize(Model.MonthlyFineRevenue.Select(x => x.Month)));
            const data = @Html.Raw(Json.Serialize(Model.MonthlyFineRevenue.Select(x => x.Revenue)));

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Revenue',
                        data: data,
                        fill: true,
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        tension: 0.3,
                        pointBackgroundColor: '#0d6efd',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) { return '$' + value.toLocaleString(); }
                            }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        });
    </script>
}