@model IEnumerable<Library_Management_System.Web.Models.Fine>

@{
    ViewData["Title"] = "Fine Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Fine Management</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm me-1"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary">Outstanding Unpaid Fines</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Borrower</th>
                            <th>Book Title</th>
                            <th>Amount</th>
                            <th>Generated Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    No outstanding fines found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold">@item.BorrowTransaction.User?.FullName</div>
                                        <div class="small text-muted">@item.BorrowTransaction.User?.Email</div>
                                    </td>
                                    <td>@item.BorrowTransaction.Book?.Title</td>
                                    <td class="fw-bold text-danger">@item.Amount.ToString("C")</td>
                                    <td class="small text-muted">@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    <td class="text-end pe-4">
                                        <form asp-action="MarkPaid" asp-route-id="@item.FineId" method="post" 
                                              onsubmit="return confirm('Mark this fine as paid?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-check me-1"></i> Mark as Paid
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>