@model IEnumerable<Library_Management_System.Web.Models.Transaction>

@{
    ViewData["Title"] = "Transaction History";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Transaction History</h1>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 fw-bold text-primary">All System Activities</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="small text-uppercase text-muted">
                            <th class="ps-4">Date</th>
                            <th>User</th>
                            <th>Book</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th class="pe-4">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted italic">
                                    No transactions recorded in the history.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 small">@item.TransactionDate.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td>
                                        <div class="fw-bold">@item.User?.FullName</div>
                                        <div class="small text-muted">@item.User?.Email</div>
                                    </td>
                                    <td class="small">@item.Book?.Title</td>
                                    <td>
                                        @{
                                            var badgeClass = item.TransactionType switch
                                            {
                                                "Borrow" => "bg-primary",
                                                "Return" => "bg-success",
                                                "Reservation" => "bg-info text-dark",
                                                "Fine Payment" => "bg-warning text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge rounded-pill @badgeClass">@item.TransactionType</span>
                                    </td>
                                    <td class="fw-bold @(item.Amount.HasValue ? "text-success" : "")">
                                        @(item.Amount.HasValue ? item.Amount.Value.ToString("C") : "-")
                                    </td>
                                    <td class="pe-4 small text-muted">@item.Description</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>