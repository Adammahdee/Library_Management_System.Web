@model Library_Management_System.Web.Models.BorrowTransaction

@{
    ViewData["Title"] = "Transaction Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid px-4">
    <div class="d-flex align-items-center justify-content-between mb-4 mt-4">
        <h1 class="h3 mb-0 text-dark fw-bold">Transaction Details</h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm me-1"></i> Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Loan Information</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Book Title</div>
                        <div class="col-sm-8 text-dark fw-bold">@Model.Book?.Title</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Borrower</div>
                        <div class="col-sm-8 text-dark">@Model.User?.FullName (@Model.User?.Email)</div>
                    </div>
                    <hr class="text-light" />
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Borrowed On</div>
                        <div class="col-sm-8 text-dark">@Model.BorrowDate.ToLocalTime().ToString("f")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Due Date</div>
                        <div class="col-sm-8 text-dark">@Model.DueDate.ToLocalTime().ToString("D")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Returned On</div>
                        <div class="col-sm-8 text-dark">
                            @(Model.ReturnDate.HasValue ? Model.ReturnDate.Value.ToLocalTime().ToString("f") : "Not Returned")
                        </div>
                    </div>
                    <div class="row mb-0">
                        <div class="col-sm-4 text-muted small fw-bold text-uppercase">Status</div>
                        <div class="col-sm-8">
                            <span class="badge rounded-pill @(Model.Status == "Borrowed" ? "bg-primary" : Model.Status.Contains("Overdue") ? "bg-danger" : "bg-success")">
                                @Model.Status
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-primary">Associated Fines</h6>
                </div>
                <div class="card-body p-0">
                    @if (Model.Fines != null && Model.Fines.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var fine in Model.Fines)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-bold text-danger">@fine.Amount.ToString("C")</div>
                                        <div class="small text-muted">Generated: @fine.CreatedAt.ToLocalTime().ToShortDateString()</div>
                                    </div>
                                    <span class="badge @(fine.IsPaid ? "bg-success" : "bg-warning text-dark")">@(fine.IsPaid ? "Paid" : "Unpaid")</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No fines associated with this transaction.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>